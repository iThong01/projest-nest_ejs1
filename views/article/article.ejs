<!DOCTYPE html>
<html data-theme="nature">

<head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <title>Herb Articles</title>
    <meta name='viewport' content='width=device-width, initial-scale=1'>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
    <style>
        @theme {
            --color-herb-50: #f0fdf4;
            --color-herb-100: #dcfce7;
            --color-herb-200: #bbf7d0;
            --color-herb-300: #86efac;
            --color-herb-400: #4ade80;
            --color-herb-500: #22c55e;
            --color-herb-600: #16a34a;
            --color-herb-700: #15803d;
            --color-herb-800: #166534;
            --color-herb-900: #14532d;
        }
    </style>
</head>

<body class="bg-base-200 min-h-screen flex flex-col font-sans">
    <%- include('../partials/navbar') %>

    <!-- Hero Section -->
    <div class="hero min-h-[40vh] relative overflow-hidden">
        <!-- Background Image with Overlay -->
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1540420773420-3366772f4999?q=80&w=2000&auto=format&fit=crop');"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-herb-900/90 to-herb-800/70"></div>
        
        <div class="hero-content text-center text-neutral-content relative z-10 py-16">
            <div class="max-w-xl">
                <div class="inline-block px-4 py-1 rounded-full bg-herb-100/20 text-herb-100 backdrop-blur-sm text-sm font-semibold mb-6 border border-herb-100/30">
                    🌿 ธรรมชาติบำบัด
                </div>
                <h1 class="mb-6 text-5xl font-extrabold tracking-tight text-white drop-shadow-xl">Blog Herbal</h1>
                <p class="mb-8 text-xl font-light text-herb-50 drop-shadow-md leading-relaxed">
                    แหล่งรวมความรู้เรื่องสมุนไพร เพื่อการดูแลสุขภาพและชีวิตที่ยืนยาวอย่างเป็นธรรมชาติ
                </p>
                <div class="flex justify-center gap-4">
                    <button class="btn btn-success text-white rounded-full px-8 shadow-lg shadow-green-600/30 border-none bg-herb-600 hover:bg-herb-700">อ่านบทความล่าสุด</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full -mt-8 relative z-20">
        
        <!-- Category & Filter -->
        <div class="bg-base-100 rounded-2xl shadow-sm border border-base-300 p-4 mb-10 flex flex-col sm:flex-row items-center justify-between gap-4">
            <h2 class="text-2xl font-bold text-herb-800 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-herb-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H15" /></svg>
                บทความทั้งหมด
            </h2>
            <div class="tabs tabs-box bg-base-200 p-1 rounded-lg">
                <a class="tab tab-active bg-base-100 shadow-sm text-herb-700 font-medium rounded-md">ทั้งหมด</a>
                <a class="tab hover:text-herb-600 transition-colors">ยอดนิยม</a>
                <a class="tab hover:text-herb-600 transition-colors">สมุนไพรไทย</a>
            </div>
        </div>

        <!-- Articles Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

            <% Item.forEach(function(product) { %>
            <article class="card bg-base-100 shadow-md hover:shadow-xl border border-base-200 transition-all duration-300 group overflow-hidden flex flex-col h-full rounded-2xl">
                <figure class="h-56 overflow-hidden relative">
                    <img src="https://images.unsplash.com/photo-1620606703565-df0a8d423984?q=80&w=800&auto=format&fit=crop" alt="Holy Basil" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                    <div class="absolute top-4 left-4">
                        <span class="badge badge-success text-white shadow-md font-medium border-none bg-herb-600 py-3 px-4"><%= product.name%></span>
                    </div>
                </figure>
                <div class="card-body p-6 flex flex-col flex-grow">
                    <div class="flex items-center justify-between mb-3 text-xs text-base-content/60 font-medium uppercase tracking-wider">
                        <div class="flex items-center gap-1.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-herb-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                            <span><%= product.date %></span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-herb-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            <span>5 min read</span>
                        </div>
                    </div>
                    

                    <h3 class="card-title text-xl font-bold text-base-content mb-3 leading-snug group-hover:text-herb-700 transition-colors line-clamp-2">
                        <%= product.head%>
                    </h3>
                    <p class="text-base-content/70 text-sm leading-relaxed mb-6 flex-grow line-clamp-3">
                        <%= product.detail %>
                        </p>

                    <div class="mt-auto pt-4 border-t border-base-200 flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="avatar placeholder">
                                <div class="bg-herb-100 text-herb-700 rounded-full w-10 border border-herb-200">
                                    <span class="font-bold text-sm flex items-center justify-center h-full">TT</span>
                                </div>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-base-content m-0">Thanomrod Thong</p>
                                <p class="text-xs text-base-content/50 m-0">ผู้เชี่ยวชาญสมุนไพร</p>
                            </div>
                        </div>
                        <button class="btn btn-circle btn-ghost btn-sm text-herb-600 hover:bg-herb-50">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform -rotate-45 group-hover:rotate-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                        </button>
                    </div>
                </div>
            </article>
            <%});%>
        </div>

        <!-- Pagination -->
        <div class="flex justify-center mt-14 mb-8">
            <div class="join shadow-sm">
                <button class="join-item btn bg-base-100 border-base-300 hover:bg-herb-50 text-base-content">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                </button>
                <button class="join-item btn btn-active bg-herb-600 text-white border-herb-600 hover:bg-herb-700">1</button>
                <button class="join-item btn bg-base-100 border-base-300 hover:bg-herb-50 text-base-content">2</button>
                <button class="join-item btn bg-base-100 border-base-300 hover:bg-herb-50 text-base-content">3</button>
                <button class="join-item btn bg-base-100 border-base-300 hover:bg-herb-50 text-base-content">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </button>
            </div>
        </div>
        
    </main>

    <%- include('../partials/footer') %>
</body>

</html>
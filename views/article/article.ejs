<!DOCTYPE html>
<html data-theme="nature">

<head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <title>Herb Articles</title>
    <meta name='viewport' content='width=device-width, initial-scale=1'>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
</head>

<body class="bg-base-200 min-h-screen flex flex-col font-sans">
    <%- include('../partials/navbar')%>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full -mt-8 relative z-20">
        
        <div class="bg-base-100 rounded-2xl shadow-sm border border-base-300 p-4 mb-10 flex flex-col sm:flex-row items-center justify-between gap-4">
            <h2 class="text-2xl font-bold text-primary flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H15" /></svg>
                บทความทั้งหมด
            </h2>
            <div class="tabs tabs-box bg-base-200 p-1 rounded-lg">
                <a class="tab tab-active bg-base-100 shadow-sm text-neutral font-medium rounded-md">ทั้งหมด</a>
                <a class="tab hover:text-primary transition-colors">ยอดนิยม</a>
                <a class="tab hover:text-primary transition-colors">สมุนไพรไทย</a>
            </div>
            <% if (session && session.role === 'admin') { %>
                    <a href="/article/create" class="btn btn-primary text-white shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                        เพิ่มบทความ
                    </a>
            <% } %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

            <% Item.forEach(function(product) { %>
            <article class="card bg-base-100 shadow-md hover:shadow-xl border border-base-200 transition-all duration-300 group overflow-hidden flex flex-col h-full rounded-2xl">
                <% if (session && session.role === 'admin') { %>
                <div class="absolute top-4 right-4">
                        <form action="/article/delete/<%= product.id %>" method="POST" onsubmit="return confirm('คุณแน่ใจหรือไม่ว่าจะลบ?');       ;">
                            <button type="submit" class="btn btn-sm bg-red-500 hover:bg-red-500 border-none text-white shadow-md">
                                ลบบทความ
                            </button>
                        </form>
                </div>
                <% } %>
                <div class="card-body p-6 flex flex-col flex-grow">
                    <div class="flex items-center justify-between mb-3 text-xs text-base-content/60 font-medium uppercase tracking-wider">
                        <div class="flex items-center gap-1.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary/70" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                            <span><%= product.date %></span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary/70" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            <span>5 min read</span>
                        </div>
                    </div>
                    

                    <h3 class="card-title text-xl font-bold text-base-content mb-3 leading-snug group-hover:text-neutral transition-colors line-clamp-2">
                        <%= product.head%>
                    </h3>
                    <p class="text-base-content/70 text-sm leading-relaxed mb-6 flex-grow line-clamp-3">
                        <%= product.detail %>
                        </p>

                    <div class="mt-auto pt-4 border-t border-base-200 flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="avatar placeholder">
                                <div class="bg-primary/20 text-primary rounded-full w-10 border border-primary/30">
                                    <span class="font-bold text-sm flex items-center justify-center h-full">TT</span>
                                </div>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-base-content m-0">Thanomrod Thong</p>
                                <p class="text-xs text-base-content/50 m-0">ผู้เชี่ยวชาญสมุนไพร</p>
                            </div>
                        </div>
                        <button class="btn btn-circle btn-ghost btn-sm text-primary hover:bg-base-200">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform -rotate-45 group-hover:rotate-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                        </button>
                    </div>
                </div>
            </article>
            <%});%>
        </div>

        <div class="flex justify-center mt-14 mb-8">
            <div class="join shadow-sm">
                <button class="join-item btn bg-base-100 border-base-300 hover:bg-base-200 text-base-content">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                </button>
                <button class="join-item btn btn-active btn-primary text-white border-primary">1</button>
                <button class="join-item btn bg-base-100 border-base-300 hover:bg-base-200 text-base-content">2</button>
                <button class="join-item btn bg-base-100 border-base-300 hover:bg-base-200 text-base-content">3</button>
                <button class="join-item btn bg-base-100 border-base-300 hover:bg-base-200 text-base-content">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </button>
            </div>
        </div>
        
    </main>

    <%- include('../partials/footer') %>
</body>

</html>
<!DOTYPE html>
    <html data-theme="nature">

    <head>
        <meta charset='utf-8'>
        <meta http-equiv='X-UA-Compatible' content='IE=edge'>
        <title>เขียนบทความใหม่</title>
        <meta name='viewport' content='width=device-width, initial-scale=1'>
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
        <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
    </head>

    <body class="bg-base-200 min-h-screen flex flex-col font-sans">
        <%- include('../partials/navbar') %>

            <main class="flex-grow max-w-3xl mx-auto px-4 py-10 w-full">
                <div class="bg-base-100 rounded-2xl shadow-lg p-8">
                    <h1 class="text-3xl font-bold text-primary mb-6 border-b pb-4"> เขียนบทความใหม่</h1>

                    <form action="/article/create" method="POST" class="space-y-6">

                        <div class="form-control w-full">
                            <label class="label">
                                <span class="label-text font-semibold">ชื่อสมุนไพร</span>
                            </label>
                            <input type="text" name="name" placeholder="เช่น กะเพรา, ฟ้าทะลายโจร,..."
                                class="input input-bordered w-full" required />
                        </div>

                        <div class="form-control w-full">
                            <label class="label">
                                <span class="label-text font-semibold">หัวข้อบทความ</span>
                            </label>
                            <input type="text" name="head" placeholder="เช่น ประโยชน์ของกะเพรา 10 ข้อ"
                                class="input input-bordered w-full" required />
                        </div>

                        <div class="form-control w-full">
                            <label class="label">
                                <span class="label-text font-semibold">เนื้อหา</span>
                            </label>
                            <textarea name="detail" class="textarea textarea-bordered h-40 w-full"
                                placeholder="พิมพ์เนื้อหาที่นี่..." required></textarea>
                        </div>

                        <div class="flex justify-end gap-4 mt-8">
                            <a href="/article" class="btn btn-ghost">ยกเลิก</a>
                            <button type="submit" class="btn btn-primary text-white">บันทึกบทความ</button>
                        </div>
                    </form>

                </div>
            </main>
            <%- include('../partials/footer') %>
    </body>

    </html>
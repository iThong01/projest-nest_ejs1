<!DOCTYPE html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title></title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
</head>

<body class="bg-gray-50 font-sans text-gray-800 flex items-center justify-center min-h-screen">
    <div class="max-w-md w-full bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-extrabold text-green-800">Register</h2>
            <p class="mt-2 text-sm text-gray-500">สร้างบัญชี Green Market</p>
        </div>

        <form action="/login/Register" method="post" class="space-y-6">
            <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input type="text" id="name" name="name" placeholder="Name..." required
                    class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm"
                    title="กรอกเฉพาะตัวอักษร" pattern="[A-Za-zก-ฮ\s]+"
                    oninput="this.value = this.value.replace(/[0-9]/g,'')">
            </div>
            <div>
                <label for="lname" class="block text-sm font-medium text-gray-700 mb-1">Last name</label>
                <input type="text" id="lname" name="lname" placeholder="Last name..." required
                    class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm"
                    title="กรอกเฉพาะตัวอักษร" pattern="[A-Za-zก-๙s]+"
                    oninput="this.value = this.value.replace(/[0-9]/g,'')">
            </div>
            <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" id="email" name="email" placeholder="Email..." required
                    class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm">
            </div>
            <div>
                <label for="user" class="block text-sm font-medium text-gray-700 mb-1">User Name</label>
                <input type="text" id="user" name="user" placeholder="username..." required
                    class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm">
            </div>
            <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <input type="password" id="password" name="password" placeholder="password..." required
                    class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm">

                <div id="password-strong" class="mt-2 hidden">
                    <div class="flex justify-between items-center mb-1">
                        <span class="text-xs font-semibold text-gray-500">ความปลอดภัย:</span>
                        <span id="strength-text" class="text-xs font-bold text-gray-500">typin...</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div id="strength-bar" class="bg-gray-400 h-2 rounded-full transition-all duration-300 w-0"></div>
                    </div>
                    <p id="password-hint" class="text-xs text-gray-500 mt-1">ต้องมีอย่างน้อย 8 ตัว, ตัวพิมพ์ใหญ่, ตัวพิมพ์เล็ก และตัวเลข</p>
                </div>
            </div>
            <div>
                <label for="confirm_password" class="block text-sm font-medium text-gray-700 mb-1">Confirm
                    Password</label>
                <input type="password" id="confirm_password" name="confirm_password" placeholder="Confirm password..."
                    required class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2
      focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm">
                <p id="match-message" class="text-xs text-red-500 mt-1 hidden font-semibold">รหัสผ่านไม่ตรงกัน</p>
            </div>
            <div class="flex gap-4 pt-2">
                <button type="reset"
                    class="w-1/2 flex justify-center py-3 px-4 border border-gray-300 rounded-lg shadow-sm text-sm font-bold text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors">
                    Reset
                </button>
                <button type="submit"
                    class="w-1/2 flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors">
                    Submit
                </button>
            </div>
        </form>

        <div class="mt-6 text-center border-t border-gray-100 pt-6">
            <p class="text-sm text-gray-600">
                มีบัญชีอยู่แล้วป่าว?
                <a href="/login" class="font-semibold text-green-600 hover:text-green-500 transition-colors">
                    Login Here
                </a>
            </p>
        </div>

    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script>
        $(document).ready(function () {
            const passwordInput = $('#password');
            const confirmPass = $('#confirm_password');
            const strengthCon = $('#password-strong');
            const strengthBar = $('#strength-bar');
            const strengthText = $('#strength-text');
            const matchMessage = $('#match-message');
            const submit = $('button[type="submit"]');

            passwordInput.on('input', function () {
                const val = $(this).val();
                let score = 0;
                if (val.length > 0) {
                    strengthCon.removeClass('hidden');
                } else {
                    strengthCon.addClass('hidden');
                    strengthText.text('wait typing..').attr('class', 'text-xs font-bold text-gray-500');
                    strengthBar.attr('class', 'h-2 rounded-full transition-all duration-300 w-0 bg-gray-400');
                    return;
                }
                $.ajax({
                    url: '/login/check-password',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ password: val }),
                    success: function (res) {
                        strengthText.text(res.message).attr('class', 'text-xs font-bold ' + res.colorClass);
                        strengthBar.attr('class', 'h-2 rounded-full transition-all duration-300 ' + res.widthClass);
                    },
                    error: function (err) {
                        console.error('AJAX Error: ', err);
                    }
                });
                checkPasswordMatch();
            });

            confirmPass.on('input', checkPasswordMatch);

            function checkPasswordMatch() {
                const pass = passwordInput.val();
                const confirmPassword = confirmPass.val();

                if (confirmPassword.length > 0) {
                    if (pass === confirmPassword) {
                        matchMessage.addClass('hidden');
                        submit.prop('disabled', false).removeClass('opacity-50 cursor-not-allowed');
                        confirmPass.removeClass('border-red-500 focus:border-red-500').addClass('border-green-500 focus:border-green-500');
                    } else {
                        matchMessage.removeClass('hidden');
                        submit.prop('disabled', true).addClass('opacity-50 cursor-not-allowed');
                        confirmPass.removeClass('border-green-500 focus:border-green-500').addClass('border-red-500 focus:border-red-500');
                    }
                } else {
                    matchMessage.addClass('hidden');
                    confirmPass.removeClass('border-red-500 border-green-500 focus:border-red-500 focus:border-green-500');
                }
            }
        });
    </script>
</body>

</html>
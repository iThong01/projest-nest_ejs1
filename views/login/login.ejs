<!DOCTYPE html>

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title></title>
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
        <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
    </head>

    <body class="bg-green-200 font-sans text-gray-800 antialiased min-h-screen flex flex-col">
        <%- include('../partials/navbar') %>

        <main class="flex-grow flex items-center justify-center p-4">
            <div class="max-w-md w-full bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
                <% if (typeof session !== 'undefined' && session.username) { %>
                <div class="text-center mb-8">
                    <h2 class="text-3xl font-extrabold text-green-800">Welcome Back</h2>
                    <p class="mt-2 text-lg font-semibold text-gray-700"><%= session.username %></p>
                    <% if (session.role) { %>
                    <p class="mt-1 text-sm text-gray-500">Role: <%= session.role %></p>
                    <% } %>
                </div>
                
                <a href="/login/logout" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors mt-4">
                    Logout
                </a>
                <% } else { %>
                <div class="text-center mb-8">
                    <h2 class="text-3xl font-extrabold text-green-800">Login</h2>
                    <p class="mt-2 text-sm text-gray-500">Welcome to Green Market</p>
                </div>
                
                <% if (typeof errorMsg !== 'undefined') { %>
                <div class="mb-4 p-3 bg-red-100 border border-red-400 text-red-700 rounded text-center text-sm font-bold">
                    <%= errorMsg %>
                </div>
                <% } %>
                
                <form action="/login" method="POST">
                <input type="hidden" name="action" value="login">
                <div class="mb-4">
                    <label for="user" class="block text-sm font-medium text-gray-700 mb-1">User</label>
                    <input type="text" id="user" name="user" placeholder="Enter your username..." required
                        class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm">
                </div>
                <div class="mb-4">
                    <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <input type="password" id="password" name="password" placeholder="Enter your password..." required
                        class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm">
                </div>
                <a href="/login/forgetPass"
                    class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-green-700 bg-white-600 hover:bg-whitefocus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors mt-4">Forget
                    password</a>
                <button type="submit" value="sendData"
                    class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors mt-4">
                    Sign in
                </button>
                </form>

                <div class="mt-6 text-center">
                    <p class="text-sm text-gray-600">
                        Have User Yet?
                        <a href="/login/Register"
                            class="font-semibold text-green-600 hover:text-green-500 transition-colors">
                            Register Now
                        </a>
                    </p>
                </div>
                <% } %>
            </div>
        </main>
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    </body>

    </html>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<nav
    class="sticky top-0 z-50 bg-green-500/90 backdrop-blur-md shadow-sm after:pointer-events-none after:absolute after:inset-x-0 after:bottom-0 after:h-px after:bg-white/10 transition-all duration-300">
    <div class="mx-auto max-w-7xl px-2 sm:px-6 lg:px-8">
        <div class="relative flex h-16 items-center justify-between">
            <div class="absolute inset-y-0 left-0 flex items-center sm:hidden">
                <button type="button" command="--toggle" commandfor="mobile-menu"
                    class="relative inline-flex items-center justify-center rounded-md p-2 text-black-400 hover:bg-white/5 hover:text-white focus:outline-2 focus:-outline-offset-1 focus:outline-indigo-500">
                    <span class="absolute -inset-0.5"></span>
                    <span class="sr-only">Open main menu</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon"
                        aria-hidden="true" class="size-6 in-aria-expanded:hidden">
                        <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round"
                            stroke-linejoin="round" />
                    </svg>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon"
                        aria-hidden="true" class="size-6 not-in-aria-expanded:hidden">
                        <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
            </div>
            <div class="flex flex-1 sm:flex-none items-center justify-center sm:items-stretch sm:justify-start">
                <div class="flex shrink-0 items-center text-2xl text-green-800 font-semibold">
                    Green Market
                </div>
                <div class="hidden sm:ml-6 sm:block">
                    <div class="flex space-x-4">
                        <a href="/" aria-current="page"
                            class="rounded-md <%= activeMenu === 'index' ? 'bg-white text-green-700 shadow-md hover:scale-105' : 'text-green-900 hover:bg-green-700 hover:text-white hover:scale-105' %>  px-3 py-2 text-sm font-medium text-green-750 transition-all duration-300">
                            Home</a>
                        <a href="/shop"
                            class="rounded-md px-3 py-2 text-sm font-bold transition-all duration-300 <%= activeMenu === 'shop' ? 'bg-white text-green-700 shadow-md hover:scale-105' : 'text-green-900 hover:bg-green-700 hover:text-white hover:scale-105' %>">
                            Shop</a>
                        <a href="/article"
                            class="rounded-md px-3 py-2 text-sm font-bold transition-all duration-300 <%= activeMenu === 'article' ? 'bg-white text-green-700 shadow-md hover:scale-105' : 'text-green-900 hover:bg-green-700 hover:text-white hover:scale-105' %>">
                            Article</a>
                    </div>
                </div>
            </div>
            <div class="hidden sm:flex flex-1 items-center justify-center px-4 lg:px-8">
                <form action="/shop/search" method="GET" class="relative w-full max-w-lg">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                        <svg class="w-4 h-4 text-gray-600" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                            fill="none" viewBox="0 0 20 20">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z" />
                        </svg>
                    </div>
                    <input type="text" name="q"
                        class="block w-full py-1.5 pl-10 pr-4 text-sm text-gray-900 border border-white/30 rounded-full bg-white/70 focus:outline-none focus:ring-2 focus:ring-green-500 focus:bg-white transition-all"
                        placeholder="Search...">
                </form>
            </div>
            <div class="absolute inset-y-0 right-0 flex shrink-0 items-center pr-2 sm:static sm:inset-auto sm:pr-0">
                <a type="button" href="/shop/Your-Basket" id="basket-button"
                    class="size-10 relative flex items-center justify-center rounded-full transition-all duration-300 hover:scale-110 <%= activeMenu==='basket' ? 'bg-green-700 shadow-md' : 'bg-white/30 hover:bg-green-600' %>">
                    <span class="absolute -inset-1.5"></span>
                    <span class="sr-only">View baskets</span>
                    <img src="/icons/shopping-cart.png" alt="Basket" class="size-6" />
                        <span id="cart-badge" class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-red-500 text-[10px] 
                        font-bold text-white shadow-sm ring-2 ring-green-500 animate-bounce"style="<%= (typeof ItemCartCount !== 'undefined' && ItemCartCount > 0) ? '' : 'display: none;' %>">
                            <%= (typeof ItemCartCount !== 'undefined' && ItemCartCount > 0) ? ItemCartCount : '' %>
                        </span>
                </a>
                <div class="relative ml-4" id="user-menu-container">
                    <% if (typeof session !=='undefined' && session.username) { %>
                        <button type="button" id="user-menu-button" class="flex items-center gap-2 relative rounded-full focus:outline-none focus:ring-2
      focus:ring-white transition-transform hover:scale-105">
                            <span class="sr-only">Open user menu</span>
                            <div class="avatar online placeholder shadow-md">
                                <div
                                    class="bg-yellow-400 text-green-900 w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg ring-2 ring-white">
                                    <span>
                                        <%= session.username.charAt(0).toUpperCase() %>
                                    </span>
                                </div>
                            </div>
                            <span class="hidden sm:block text-sm font-bold text-white drop-shadow-md">
                                <%= session.username %>
                            </span>
                            <svg class="w-4 h-4 text-white hidden sm:block" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </button>
                        <div id="user-dropdown" class="absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white py-1 shadow-xl ring-1 ring-black
      ring-opacity-5" style="display: none;">
                            <div class="px-4 py-3 border-b border-gray-100 bg-gray-50 rounded-t-md">
                                <p class="text-xs text-gray-500">เข้าสู่ระบบในชื่อ</p>
                                <p class="text-sm font-bold text-green-700 truncate">
                                    <%= session.username %>
                                </p>
                                </div>
                            <a href="/profile"
                                class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-green-50 hover:text-green-700 transition-colors">⚙️
                                โปรไฟล์ของฉัน</a>
                            <a href="/shop/orders"
                                class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-green-50 hover:text-green-700 transition-colors">📦
                                ประวัติการสั่งซื้อ</a>
                            <a href="/login/logout"
                                class="block px-4 py-2.5 text-sm text-red-600 font-bold hover:bg-red-50 transition-colors">🚪
                                ออกจากระบบ</a>
                            </div>
                        <% } else { %>
                            <a href="/login" class="flex items-center gap-2 bg-white text-green-700 px-5 py-2 rounded-full font-bold shadow-lg hover:bg-yellow-400
      hover:text-green-900 hover:scale-105 transition-all duration-300">
                                <img src="/icons/user.png" alt="Login" class="size-5" />
                                <span>เข้าสู่ระบบ</span>
                                </a>
                            <% } %>
                </div>
            </div>
        </div>
    </div>

    <el-disclosure id="mobile-menu" hidden class="block sm:hidden">
        <div class="space-y-1 px-2 pt-2 pb-3">
            <div class="mb-4 mt-2 px-2">
                <form action="/shop/search" method="GET" class="relative">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                        <svg class="w-4 h-4 text-gray-500" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                            fill="none" viewBox="0 0 20 20">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z" />
                        </svg>
                    </div>
                    <input type="text" name="q"
                        class="block w-full p-2.5 pl-10 text-sm text-gray-900 border border-gray-300 rounded-lg bg-gray-50 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500"
                        placeholder="Search...">
                </form>
            </div>
            <a href="/" aria-current="page"
                class="block rounded-md bg-gray-950/50 px-3 py-2 text-base font-medium text-white">Home</a>
            <a href="/shop"
                class="block rounded-md px-3 py-2 text-base font-medium text-gray-300 hover:bg-white/5 hover:text-white">Shop</a>
            <a href="/article"
                class="block rounded-md px-3 py-2 text-base font-medium text-gray-300 hover:bg-white/5 hover:text-white">Articles</a>
        </div>
    </el-disclosure>
</nav>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
    $(document).ready(function(){
        $('#user-menu-button').click(function(event){
            event.stopPropagation();
            $('#user-dropdown').fadeToggle('fast');
        });
        $(document).click(function(event){
            if(!$(event.target).closest('#user-menu-button,#user-dropdown').length){
                $('#user-dropdown').fadeOut('fast');
            }
        });
    });
</script>
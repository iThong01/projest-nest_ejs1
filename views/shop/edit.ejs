<!DOCTYPE html>
<html lang="en" data-theme="cupcake">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Item - <%= item.name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@3.9.0/dist/full.css" rel="stylesheet" type="text/css" />
</head>
<body class="bg-base-200 min-h-screen flex items-center justify-center p-4">

    <div class="card w-full max-w-lg bg-base-100 shadow-xl border-t-4 border-success">
        <div class="card-body">
            <h2 class="card-title text-2xl font-bold text-success mb-6 border-b pb-2">
                แก้ไขข้อมูลสินค้าสมุนไพร
            </h2>

            <form action="/shop/edit/<%= item.id %>" method="POST" enctype="multipart/form-data" class="space-y-4">

                <!-- ชื่อสินค้า -->
                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-semibold">ชื่อสมุนไพร</span>
                    </label>
                    <input type="text" name="name" value="<%= item.name %>" class="input input-bordered input-success w-full" required />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="form-control w-full">
                        <label class="label">
                            <span class="label-text font-semibold">ราคา (฿)</span>
                        </label>
                        <input type="number" step="0.01" name="price" value="<%= item.price %>" class="input input-bordered input-success w-full" required />
                    </div>
                    <div class="form-control w-full">
                        <label class="label">
                            <span class="label-text font-semibold">สต๊อก</span>
                        </label>
                        <input type="number" name="count" value="<%= item.count %>" class="input input-bordered input-success w-full" required />
                    </div>
                </div>

                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-semibold">รายละเอียด</span>
                    </label>
                    <textarea name="description" class="textarea textarea-bordered textarea-success h-24" required><%= item.description %></textarea>
                </div>

                <div class="form-control w-full bg-base-200 p-4 rounded-box mt-2">
                    <span class="label-text font-semibold mb-2 block">รูปภาพปัจจุบัน</span>
                    <div class="flex justify-center bg-white p-2 rounded-lg border border-base-300">
                        <img src="data:image/jpeg;base64,<%= item.image %>" alt="<%= item.name %>" class="max-h-32 object-contain rounded-md shadow-sm">
                    </div>
                </div>

                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-semibold text-warning">เปลี่ยนรูปภาพมั้ย</span>
                    </label>
                    <input type="file" name="image" accept="image/*" class="file-input file-input-bordered file-input-success w-full" />
                </div>

                <div class="card-actions justify-end mt-6 pt-4 border-t border-base-200">
                    <a href="/shop/Manage" class="btn btn-ghost">ยกเลิก</a>
                    <button type="submit" class="btn btn-success text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        บันทึก
                    </button>
                </div>
            </form>
        </div>
    </div>

</body>
</html>